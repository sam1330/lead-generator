# Application
PORT=3000

# Database (used directly when running outside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_generator

# Postgres (used by docker-compose to configure the postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lead_generator
POSTGRES_PORT=5432

# Telegram
TELEGRAM_BOT_TOKEN=

# Optional: set this to use webhook mode instead of polling
# Must be a publicly accessible HTTPS URL pointing to /webhook on this app
TELEGRAM_WEBHOOK_URL=

# Google AI (Gemini)
GOOGLE_AI_API_KEY=

# Langfuse observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
